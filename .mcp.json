{
  "mcpServers": {
    "context7": {
    "command": "cmd",
    "args": ["/c", "npx", "-y", "@upstash/context7-mcp"]
    },
    "postgresql-mcp": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@henkey/postgres-mcp-server"
      ]
    },
    "playwright": {
      "command": "cmd", "args": ["/c", "npx", "-y", "@playwright/mcp@latest"]
    },
    "chrome-devtools": {
     "command": "cmd", "args": ["/c", "npx", "-y", "chrome-devtools-mcp@latest"]
    }  
  },
  "$version": 3
}