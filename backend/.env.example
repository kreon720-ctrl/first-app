# PostgreSQL Database Connection
DATABASE_URL=

# JWT Secrets
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# JWT Expiry
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS: Frontend deployment URL (required for cross-origin API access)
# Development: http://localhost:3001
# Production: set to your Vercel frontend deployment URL
FRONTEND_URL=https://your-frontend.vercel.app
